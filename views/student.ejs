<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students</title>


    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Segoe UI, Arial, sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a, #1e293b, #4338ca);
            padding: 40px 20px;
        }

        h1 {
            text-align: center;
            color: white;
            margin-bottom: 35px;
            font-size: 3rem;
            letter-spacing: 1px;
        }

        .home {
            display: inline-block;
            text-decoration: none;
            color: white;
            padding: 14px 24px;
            border-radius: 12px;
            background: linear-gradient(135deg, #10b981, #059669);
            font-weight: 600;
            margin-bottom: 30px;
            transition: .3s;
        }

        .home:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(16, 185, 129, .35);
        }

        .container {
            max-width: 1200px;
            margin: auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 25px;
        }

        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 24px;
            padding: 25px;
            color: white;
            box-shadow: 0 15px 35px rgba(0, 0, 0, .25);
            transition: .3s ease;
        }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 45px rgba(0, 0, 0, .35);
        }

        .card::before {
            content: "👨‍🎓";
            display: block;
            text-align: center;
            font-size: 60px;
            margin-bottom: 15px;
        }

        .card p {
            margin: 12px 0;
            font-size: 16px;
            line-height: 1.6;
        }

        .card strong {
            color: #93c5fd;
        }

        .actions {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .actions a {
            flex: 1;
            text-align: center;
            text-decoration: none;
            color: white;
            padding: 12px;
            border-radius: 12px;
            font-weight: 600;
            transition: .3s;
        }

        .edit {
            background: linear-gradient(135deg, #2563eb, #3b82f6);
        }

        .edit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(37, 99, 235, .35);
        }

        .delete {
            background: linear-gradient(135deg, #ef4444, #dc2626);
        }

        .delete:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(239, 68, 68, .35);
        }

        @media(max-width:768px) {

            h1 {
                font-size: 2rem;
            }

            .container {
                grid-template-columns: 1fr;
            }

            .actions {
                flex-direction: column;
            }
        }
    </style>
</head>

<body>

    <h1>Students Data Profile</h1>

    <a href="/" class="home">🏠 Back to Home</a>

    <div class="container">

        <% allstudent.forEach((element)=>{ %>

            <div class="card">

                <p><strong>Name:</strong>
                    <%= element.name %>
                </p>

                <p><strong>Age:</strong>
                    <%= element.age %>
                </p>

                <p><strong>Course:</strong>
                    <%= element.course %>
                </p>

                <p><strong>Email:</strong>
                    <%= element.email %>
                </p>
                <p><strong>City:</strong>
                    <%= element.city %>
                </p>

                <div class="actions">
                    <a href="/edit/<%= element._id %>" class="edit">Edit</a>

                    <a href="/delete/<%= element._id %>" class="delete">Delete</a>
                </div>

            </div>

            <% }) %>

    </div>

</body>

</html>