<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <h2>🎓 Add Student</h2>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Segoe UI, Arial, sans-serif;
    }

    body {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #0f172a, #1e293b, #4338ca);
        padding: 20px;
    }

    form {
        width: 450px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 24px;
        padding: 35px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, .3);
    }

    h2 {
        text-align: center;
        color: white;
        margin-bottom: 25px;
        font-size: 2rem;
        letter-spacing: 1px;
    }

    input {
        width: 100%;
        padding: 14px 16px;
        margin-bottom: 18px;
        border: none;
        outline: none;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.15);
        color: white;
        font-size: 15px;
        transition: .3s;
    }

    input::placeholder {
        color: rgba(255, 255, 255, .75);
    }

    input:focus {
        background: rgba(255, 255, 255, .2);
        box-shadow: 0 0 0 3px rgba(96, 165, 250, .4);
        transform: translateY(-2px);
    }

    button {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: .3s;
    }

    button:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(16, 185, 129, .35);
    }

    button:active {
        transform: translateY(0);
    }

    .home-btn {
        display: block;
        text-align: center;
        text-decoration: none;
        margin-top: 18px;
        padding: 14px;
        border-radius: 12px;
        background: linear-gradient(135deg, #2563eb, #3b82f6);
        color: white;
        font-weight: 600;
        transition: .3s;
    }

    .home-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(37, 99, 235, .35);
    }

    @media(max-width:500px) {
        form {
            width: 100%;
            padding: 25px;
        }

        h2 {
            font-size: 1.7rem;
        }
    }
</style>
</head>

<body>

    <form action="/createdata" method="post">
        <h2>Add Student</h2>

        <input type="text" name="name" placeholder="Enter The Name" required>

        <input type="number" name="age" placeholder="Enter The Age" required>

        <input type="text" name="course" placeholder="Enter The Course" required>

        <input type="email" name="email" placeholder="Enter The Email" required>

        <input type="text" name="city" placeholder="Enter The City" required>

        <button type="submit">Add Student</button>
    </form>
    <a href="/" class="home-btn">🏠 Home Page</a>

</body>

</html>